# .gitignore

# Ortam değişkenleri (asla paylaşma)
.env

# Python sanal ortamı
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Eğitilmiş modeller (büyük dosyalar — Git LFS veya lokal tut)
models/*.h5
models/*.keras
models/*.pt

# Veri seti (büyük olabilir)
dataset/
dataset_kaggle/

# Streamlit cache
.streamlit/

# macOS
.DS_Store

# Sunum ve Rapor Dosyaları (Lokalde kalacak, GitHub'da gözükmeyecek)
SOLID_ANALIZI.md
TEKNIK_RAPOR.md
TEKNIK_RAPOR.txt
PROJE_KODLARI.txt
